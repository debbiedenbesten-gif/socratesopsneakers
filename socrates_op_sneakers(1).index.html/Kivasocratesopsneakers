<script>
let pts=0,missies=0,vragen=0,parkeringen=0,bruggen=0;
let huidigBub='',selBrug=null,eqInt=null,audioCtx=null;
const wallData=[
  {q:'Wat bedoel je precies als je zegt dat de baan vol is?',likes:4,liked:false},
  {q:'Hoe voel jij je als je buitengesloten wordt?',likes:7,liked:false},
  {q:'Wat zou jij zelf doen in zijn situatie?',likes:2,liked:false}
];

function updateClock(){const d=new Date();const h=d.getHours().toString().padStart(2,'0');const m=d.getMinutes().toString().padStart(2,'0');document.getElementById('clock').textContent=h+':'+m;}
updateClock();setInterval(updateClock,30000);

function goTab(name){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.ni').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+name).classList.add('on');
  const ni=document.getElementById('ni-'+name);if(ni)ni.classList.add('on');
  document.getElementById('screen').scrollTop=0;
  if(name==='scenario')nieuweMissie();
  if(name==='wall')renderWall();
  if(name==='profiel')updateProfiel();
}

async function callAI(sys,msg){
  const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:400,system:sys,messages:[{role:'user',content:msg}]})});
  const d=await r.json();return d.content[0].text;
}

function getACtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();return audioCtx;}
function playBeat(){
  try{
    const c=getACtx(),g=c.createGain();g.gain.value=0.07;g.connect(c.destination);
    const now=c.currentTime;
    function kick(t){const o=c.createOscillator(),gk=c.createGain();o.frequency.setValueAtTime(120,t);o.frequency.exponentialRampToValueAtTime(35,t+0.12);gk.gain.setValueAtTime(0.8,t);gk.gain.exponentialRampToValueAtTime(0.001,t+0.22);o.connect(gk);gk.connect(g);o.start(t);o.stop(t+0.25);}
    function snr(t){const buf=c.createBuffer(1,Math.floor(c.sampleRate*0.12),c.sampleRate);const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*0.4;const s=c.createBufferSource(),gs=c.createGain();gs.gain.setValueAtTime(0.35,t);gs.gain.exponentialRampToValueAtTime(0.001,t+0.12);s.buffer=buf;s.connect(gs);gs.connect(g);s.start(t);}
    const b=60/90;
    for(let i=0;i<4;i++){kick(now+i*b*4);kick(now+i*b*4+b*2);snr(now+i*b*4+b);snr(now+i*b*4+b*3);}
  }catch(e){}
}
function playWin(){
  try{
    const c=getACtx(),g=c.createGain();g.gain.value=0.14;g.connect(c.destination);
    [523,659,784,1047].forEach((f,i)=>{const o=c.createOscillator(),gn=c.createGain();const t=c.currentTime+0.05+i*0.15;o.type='square';o.frequency.value=f;gn.gain.setValueAtTime(0.22,t);gn.gain.exponentialRampToValueAtTime(0.001,t+0.3);o.connect(gn);gn.connect(g);o.start(t);o.stop(t+0.35);});
  }catch(e){}
}
function spreek(txt){
  if(!txt)return;
  if('speechSynthesis' in window){window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(txt);u.lang='nl-NL';u.pitch=0.85;u.rate=0.88;window.speechSynthesis.speak(u);}
  playBeat();startEQ();setTimeout(stopEQ,3500);
}
function startEQ(){
  if(eqInt)clearInterval(eqInt);
  document.getElementById('hero-av-wrap').classList.add('playing-av');
  eqInt=setInterval(()=>{document.querySelectorAll('.eq-b').forEach(b=>{b.style.height=(18+Math.random()*78)+'%';});},130);
}
function stopEQ(){
  if(eqInt){clearInterval(eqInt);eqInt=null;}
  document.getElementById('hero-av-wrap').classList.remove('playing-av');
  [40,70,50,85,60].forEach((h,i)=>{const bars=document.querySelectorAll('.eq-b');if(bars[i])bars[i].style.height=h+'%';});
}

function fillNote(t){document.getElementById('park-txt').value=t;}
async function doeParkeer(){
  const v=document.getElementById('park-txt').value.trim();if(!v)return;
  document.getElementById('park-in').style.display='none';
  document.getElementById('park-ok').style.display='block';
  document.getElementById('park-resp').innerHTML='<span class="spin" style="border-top-color:#1D9E75"></span> Zephyr denkt na...';
  spreek('Je oordeel is geparkeerd. Goed gedaan!');
  try{
    const sys='Je bent Zephyr, AI-coach in Socrates op Sneakers. Reageer op het geparkeerde oordeel in 2 korte zinnen in het Nederlands. Erken het gevoel en moedig aan om open het gesprek in te gaan. Warm en direct.';
    const t=await callAI(sys,'Geparkeerd oordeel: "'+v+'"');
    document.getElementById('park-resp').textContent=t;spreek(t);
  }catch(e){document.getElementById('park-resp').textContent='Goed gedaan! Je oordeel staat veilig geparkeerd. Ga nu open het gesprek in.';}
  pts+=10;parkeringen++;updateStats();
}
function resetPark(){document.getElementById('park-txt').value='';document.getElementById('park-ok').style.display='none';document.getElementById('park-in').style.display='block';}

function moveLadder(v){
  v=parseInt(v);const isAbs=v<35,isCon=v>65;
  document.getElementById('ll-abs').classList.toggle('on',!isCon);
  document.getElementById('ll-con').classList.toggle('on',isCon);
  const cls=document.getElementById('clouds').querySelectorAll('.cloud');
  [0,1,2].forEach(i=>cls[i].classList.toggle('on',isAbs));
  [3,4,5].forEach(i=>cls[i].classList.toggle('on',isCon));
  let fv,ft,ex;
  if(isAbs){fv='Meningen & waarden';ft='Wat vind jij eerlijk in deze situatie?';ex='"Wat betekent vriendschap voor jou?"';}
  else if(isCon){fv='Feiten & waarnemingen';ft='Wat gebeurde er precies, en wanneer?';ex='"Wat zei hij precies om 10:45?"';}
  else{fv='In balans';ft='Verbind de feiten met het gevoel.';ex='"Wat merkte je, en wat voel jij daarbij?"';}
  document.getElementById('ldr-fv').textContent=fv;
  document.getElementById('ldr-ft').textContent=ft;
  document.getElementById('ldr-ex').textContent='Bijv: '+ex;
}

async function nieuweMissie(){
  document.getElementById('sc-load').style.display='block';
  document.getElementById('sc-content').style.display='none';
  document.getElementById('sc-fb').style.display='none';
  document.getElementById('sc-inv').style.display='block';
  document.getElementById('sc-ans').value='';
  try{
    const sys='Je bent Zephyr, AI-coach in Socrates op Sneakers. Genereer een korte unieke schoolsituatie (2-3 zinnen) over uitsluiting, roddels of groepsdruk. Eindig met: wat is een open vraag die je hier kunt stellen? Spreek de leerling direct aan. Alleen de tekst.';
    const t=await callAI(sys,'Genereer een nieuwe KiVa-missie. Maak hem anders dan vorige keren.');
    huidigBub=t;document.getElementById('sc-bub').textContent=t;
    document.getElementById('sc-load').style.display='none';document.getElementById('sc-content').style.display='block';
    spreek(t);
  }catch(e){
    huidigBub="Er zit een groepje op het plein te skaten. Als Daan aankomt, draait de groep zich om: 'De baan is nu even vol.' Wat is een open vraag die je hier kunt stellen?";
    document.getElementById('sc-bub').textContent=huidigBub;
    document.getElementById('sc-load').style.display='none';document.getElementById('sc-content').style.display='block';
  }
}
async function doeBeoordeel(){
  const ant=document.getElementById('sc-ans').value.trim();if(!ant)return;
  document.getElementById('sc-inv').style.display='none';
  const ld=document.createElement('div');ld.className='loader';ld.innerHTML='<span class="spin" style="border-top-color:#d97706"></span>Zephyr beoordeelt...';
  document.getElementById('sc-content').appendChild(ld);
  try{
    const sys='Je bent Zephyr. Beoordeel de input van de leerling. Geef ALLEEN dit JSON-object terug: {"is_open":true/false,"tip":"<korte tip in het Nederlands>"}';
    const raw=await callAI(sys,'Scenario: "'+huidigBub+'"\nAntwoord: "'+ant+'"');
    ld.remove();
    let data;try{const m=raw.match(/\{[\s\S]*\}/);data=JSON.parse(m?m[0]:raw);}catch(e){data={is_open:ant.includes('?')&&!ant.toLowerCase().match(/moet|stop|doe gewoon/),tip:'Denk na of er een oordeel in je vraag zit.'};}
    const pill=document.getElementById('sc-pill');
    pill.textContent=data.is_open?'Socratische wijsheid!':'Oordeel gespot — probeer opnieuw';
    pill.className='fb-pill '+(data.is_open?'pill-grn':'pill-amb');
    document.getElementById('sc-tip').textContent='Tip: '+data.tip;
    document.getElementById('sc-fb').style.display='block';
    if(data.is_open){pts+=15;vragen++;missies++;playWin();spreek('Socratische wijsheid! Geweldig gedaan!');}
    else spreek('Oordeel gespot. Probeer een open vraag zonder oordeel.');
    updateStats();
  }catch(e){ld.remove();document.getElementById('sc-fb').style.display='block';}
}

function kiesBrug(id){selBrug=id;[1,2,3,4].forEach(i=>document.getElementById('bo'+i).className='brug-opt'+(i===id?' sel':''));}
function testBrug(){
  if(!selBrug)return;
  const ok=selBrug===1||selBrug===3;
  [1,2,3,4].forEach(i=>document.getElementById('bo'+i).className='brug-opt'+(i===selBrug?(ok?' ok':' no'):''));
  setTimeout(()=>{
    if(ok){document.getElementById('br-kies').style.display='none';document.getElementById('br-open').style.display='block';spreek('Goed! De brug ligt er. Deel nu je inzicht.');}
    else{document.getElementById('br-kies').style.display='none';document.getElementById('br-no').style.display='block';spreek('Dat is een oordeel. Vraag eerst toestemming!');}
  },400);
}
async function doeInzicht(){
  const ins=document.getElementById('br-ins').value.trim();if(!ins)return;
  const btn=document.getElementById('br-send');btn.disabled=true;btn.innerHTML='<span class="spin"></span>';
  try{
    const sys='Je bent Zephyr. De leerling heeft toestemming gevraagd en een inzicht gedeeld. Reageer bemoedigend in 1-2 zinnen in het Nederlands. Alleen de tekst.';
    const t=await callAI(sys,'Inzicht: "'+ins+'"');
    document.getElementById('br-ai-resp').textContent=t;document.getElementById('br-ai-resp').style.display='block';
    spreek(t);
    setTimeout(()=>{document.getElementById('br-open').style.display='none';document.getElementById('br-klaar').style.display='block';playWin();pts+=20;bruggen++;updateStats();},2200);
  }catch(e){document.getElementById('br-open').style.display='none';document.getElementById('br-klaar').style.display='block';pts+=20;bruggen++;updateStats();}
}
function resetBrug(){
  selBrug=null;[1,2,3,4].forEach(i=>document.getElementById('bo'+i).className='brug-opt');
  document.getElementById('br-ins').value='';document.getElementById('br-ai-resp').style.display='none';
  const btn=document.getElementById('br-send');btn.disabled=false;btn.innerHTML='<i class="ti ti-send"></i> Deel inzicht';
  document.getElementById('br-kies').style.display='block';document.getElementById('br-open').style.display='none';
  document.getElementById('br-no').style.display='none';document.getElementById('br-klaar').style.display='none';
}

function renderWall(){
  const c=document.getElementById('wall-cards');c.innerHTML='';
  wallData.forEach((item,i)=>{
    const d=document.createElement('div');d.className='wall-card';
    d.innerHTML='<div class="wall-q">'+item.q+'</div><div class="wall-meta">Gepost door een klasgenoot</div><button class="wall-likes'+(item.liked?' liked':'')+'" onclick="likeWall('+i+')"><i class="ti ti-heart" style="font-size:15px"></i> '+item.likes+'</button>';
    c.appendChild(d);
  });
}
function likeWall(i){wallData[i].liked=!wallData[i].liked;wallData[i].likes+=wallData[i].liked?1:-1;renderWall();}
function postWall(){
  const v=document.getElementById('wall-inp').value.trim();if(!v)return;
  wallData.unshift({q:v,likes:0,liked:false});
  document.getElementById('wall-inp').value='';renderWall();pts+=5;updateStats();
  spreek('Super! Je open vraag staat op de wall!');
}

function updateStats(){
  document.getElementById('h-pts').textContent=pts;
  document.getElementById('h-mis').textContent=missies;
  document.getElementById('h-vr').textContent=vragen;
  document.getElementById('p-pts').textContent=pts;
  document.getElementById('sc-pts').textContent=pts;
}
function updateProfiel(){
  document.getElementById('prof-pts').textContent=pts;
  document.getElementById('prof-level').textContent=Math.max(1,Math.floor(pts/50)+1);
  const pp=Math.min(100,parkeringen*20),vp=Math.min(100,vragen*15),bp=Math.min(100,bruggen*25);
  document.getElementById('pp-bar').style.width=pp+'%';document.getElementById('pp-pct').textContent=pp+'%';
  document.getElementById('vr-bar').style.width=vp+'%';document.getElementById('vr-pct').textContent=vp+'%';
  document.getElementById('br-bar').style.width=bp+'%';document.getElementById('br-pct').textContent=bp+'%';
  if(parkeringen>=1)document.getElementById('badge-park').classList.add('earned');
  if(vragen>=3){document.getElementById('badge-vr').classList.add('earned');document.getElementById('badge-vr').style.opacity='1';}
  if(bruggen>=1){document.getElementById('badge-br').classList.add('earned');document.getElementById('badge-br').style.opacity='1';}
}

moveLadder(15);
renderWall();
</script>
