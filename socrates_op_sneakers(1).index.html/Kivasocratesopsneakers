<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Socrates op Sneakers — KiVa AI-training</title>
<meta name="description" content="Leer Socratisch denken met AI-coach Zephyr. KiVa-training voor leerlingen.">
<meta property="og:title" content="Socrates op Sneakers">
<meta property="og:description" content="AI-coach Zephyr leert je Socratisch denken via KiVa-missies.">
<meta property="og:type" content="website">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0f1e;--bg2:#111827;--bg3:#1a2336;--bg4:#1f2d44;
  --grn:#1D9E75;--grn2:#0f6e56;--grn3:rgba(29,158,117,0.15);--grn4:rgba(29,158,117,0.08);
  --amb:#d97706;--amb2:rgba(217,119,6,0.15);
  --blu:#378ADD;--blu2:rgba(55,138,221,0.15);
  --pur:#7F77DD;--pur2:rgba(127,119,221,0.15);
  --red:#e24b4a;
  --txt:#f1f5f9;--txt2:#94a3b8;--txt3:#64748b;
  --bdr:#1e2d42;--bdr2:#2a3f5a;
  --font:'Space Grotesk',system-ui,sans-serif;
  --mono:'DM Mono',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{background:var(--bg);font-family:var(--font);color:var(--txt);min-height:100vh;display:flex;justify-content:center;align-items:flex-start}
.phone-wrap{width:100%;max-width:420px;min-height:100vh;background:var(--bg);display:flex;flex-direction:column;position:relative;overflow:hidden}
.phone-wrap::before{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--bdr) 1px,transparent 1px),linear-gradient(90deg,var(--bdr) 1px,transparent 1px);background-size:32px 32px;opacity:0.2;pointer-events:none;z-index:0}
.statusbar{display:flex;justify-content:space-between;align-items:center;padding:12px 20px 8px;position:relative;z-index:10}
.statusbar-time{font-size:13px;font-weight:600;color:var(--txt2);font-family:var(--mono)}
.statusbar-icons{display:flex;gap:6px;align-items:center}
.statusbar-icons i{font-size:14px;color:var(--txt3)}
.eq-mini{display:flex;align-items:flex-end;gap:2px;height:16px}
.eq-b{width:3px;background:var(--grn);border-radius:1px;opacity:0.8;transition:height 0.1s}
.screen{flex:1;position:relative;z-index:1;overflow-y:auto;overflow-x:hidden;padding-bottom:72px}
.tab{display:none;animation:fadeUp 0.22s ease}
.tab.on{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:none}}
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:420px;display:flex;background:rgba(17,24,39,0.96);backdrop-filter:blur(12px);border-top:0.5px solid var(--bdr2);padding:10px 0 max(8px,env(safe-area-inset-bottom));z-index:100}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;border:none;background:none;padding:4px 0;transition:transform 0.15s}
.ni:active{transform:scale(0.9)}
.ni i{font-size:21px;color:var(--txt3);transition:color 0.15s}
.ni span{font-size:9px;color:var(--txt3);font-family:var(--font);font-weight:500;letter-spacing:0.3px;transition:color 0.15s}
.ni.on i,.ni.on span{color:var(--grn)}
.top-bar{display:flex;align-items:center;padding:12px 16px 10px;gap:10px}
.back-btn{width:32px;height:32px;border-radius:50%;background:var(--bg3);border:0.5px solid var(--bdr2);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:background 0.15s}
.back-btn:hover{background:var(--bg4)}
.back-btn i{font-size:15px;color:var(--txt2)}
.top-title{font-size:15px;font-weight:600;color:var(--txt)}
.pts-chip{margin-left:auto;display:inline-flex;align-items:center;gap:4px;background:var(--grn3);border:0.5px solid var(--grn);border-radius:20px;padding:3px 10px;font-size:11px;color:var(--grn);font-weight:600}
.home-hdr{padding:14px 16px 10px;display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:10px}
.brand-ico{width:38px;height:38px;border-radius:50%;background:var(--bg3);border:1.5px solid var(--grn);display:flex;align-items:center;justify-content:center}
.brand-ico i{font-size:18px;color:var(--grn)}
.brand-name{font-size:14px;font-weight:700;color:var(--txt)}
.brand-sub{font-size:10px;color:var(--txt3);margin-top:1px}
.notif-btn{width:34px;height:34px;border-radius:50%;background:var(--bg2);border:0.5px solid var(--bdr2);display:flex;align-items:center;justify-content:center;cursor:pointer}
.hero{margin:0 16px 14px;background:var(--bg3);border-radius:18px;border:0.5px solid var(--bdr2);padding:16px;display:flex;gap:14px;align-items:flex-start;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;top:-20px;right:-20px;width:100px;height:100px;border-radius:50%;background:var(--grn3)}
.av-wrap{position:relative;flex-shrink:0;width:80px;height:100px}
.pulse-ring{position:absolute;border-radius:50%;border:1px solid var(--grn);opacity:0}
.playing-av .pulse-ring{animation:pr 1.4s ease-out infinite}
.playing-av .pulse-ring:nth-child(2){animation-delay:0.45s}
@keyframes pr{0%{opacity:0;transform:scale(0.8)}50%{opacity:0.4}100%{opacity:0;transform:scale(1.2)}}
.playing-av svg{animation:bob 0.9s ease-in-out infinite alternate}
@keyframes bob{0%{transform:translateY(0)}100%{transform:translateY(-5px)}}
.hero-bubble{flex:1;z-index:1}
.hero-name{font-size:10px;color:var(--grn);font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:5px}
.hero-txt{font-size:13px;color:var(--txt);line-height:1.55}
.listen-btn{display:inline-flex;align-items:center;gap:4px;margin-top:8px;background:none;border:none;color:var(--blu);font-size:11px;cursor:pointer;font-family:var(--font);font-weight:500;padding:0}
.listen-btn i{font-size:14px}
.stats{display:flex;gap:8px;margin:0 16px 16px}
.stat{flex:1;background:var(--bg3);border-radius:12px;padding:10px 8px;text-align:center;border:0.5px solid var(--bdr)}
.stat-n{font-size:22px;font-weight:700;color:var(--grn);font-family:var(--mono)}
.stat-l{font-size:10px;color:var(--txt3);margin-top:2px;font-weight:500}
.section-lbl{padding:0 16px 8px;font-size:10px;color:var(--txt3);letter-spacing:1.5px;text-transform:uppercase;font-weight:600}
.mod-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:0 16px 16px}
.mod{background:var(--bg3);border-radius:14px;padding:14px;cursor:pointer;border:1px solid var(--bdr);transition:border-color 0.15s,transform 0.15s}
.mod:hover{border-color:var(--bdr2);transform:translateY(-1px)}
.mod:active{transform:scale(0.97)}
.mod-ic{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;margin-bottom:9px;font-size:16px}
.mod-n{font-size:12px;font-weight:600;color:var(--txt)}
.mod-s{font-size:10px;color:var(--txt3);margin-top:2px}
.dark-ta,.dark-inp{width:100%;background:var(--bg3);border:0.5px solid var(--bdr2);border-radius:10px;padding:12px;color:var(--txt);font-size:13px;font-family:var(--font);outline:none;transition:border-color 0.15s}
.dark-ta{resize:none;min-height:72px}
.dark-ta::placeholder,.dark-inp::placeholder{color:var(--txt3)}
.dark-ta:focus,.dark-inp:focus{border-color:var(--grn)}
.big-btn{width:100%;padding:14px;border-radius:12px;border:none;font-size:14px;font-weight:600;cursor:pointer;font-family:var(--font);display:flex;align-items:center;justify-content:center;gap:7px;transition:opacity 0.15s,transform 0.1s;letter-spacing:0.2px}
.big-btn:active{transform:scale(0.98);opacity:0.9}
.big-btn:disabled{opacity:0.45;cursor:not-allowed}
.btn-grn{background:var(--grn);color:#fff}
.btn-amb{background:var(--amb);color:#fff}
.btn-pur{background:var(--pur);color:#fff}
.btn-dim{background:var(--bg3);border:0.5px solid var(--bdr2);color:var(--txt2)}
.btn-red-out{background:transparent;border:1.5px solid var(--red);color:var(--red)}
.card{background:var(--bg3);border-radius:14px;border:0.5px solid var(--bdr2);padding:14px;margin:0 16px 12px}
.sect-lbl2{font-size:10px;color:var(--txt3);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;font-weight:600}
.ok-box{background:rgba(29,158,117,0.08);border:0.5px solid var(--grn);border-radius:12px;padding:14px;margin:0 16px 12px;font-size:13px;color:var(--txt);line-height:1.55}
.err-box{background:rgba(226,75,74,0.08);border:0.5px solid var(--red);border-radius:12px;padding:12px;margin:0 16px 10px;font-size:12px;color:#f87171;line-height:1.45}
.kiva-tip{background:var(--grn4);border:0.5px solid var(--grn);border-radius:10px;padding:11px 13px;margin:0 16px 12px}
.kiva-tip-lbl{font-size:10px;color:var(--grn);font-weight:600;margin-bottom:3px}
.kiva-tip-txt{font-size:11px;color:var(--txt2);line-height:1.45}
.notes-row{display:flex;gap:7px;margin:0 16px 12px}
.note{flex:1;border-radius:9px;padding:9px 8px;font-size:11px;font-weight:600;cursor:pointer;line-height:1.35;border:none;transition:transform 0.15s}
.note:hover{transform:rotate(-1deg) scale(1.04)}
.note.y{background:#fef08a;color:#713f12}
.note.b{background:#bfdbfe;color:#1e3a5f}
.note.p{background:#fce7f3;color:#831843}
.ldr-labels{display:flex;justify-content:space-between;margin:0 16px 6px}
.ldr-lbl{font-size:11px;color:var(--txt3);font-weight:600;transition:color 0.2s}
.ldr-lbl.on{color:var(--txt)}
.clouds{display:flex;gap:6px;margin:0 16px 12px;flex-wrap:wrap}
.cloud{background:var(--bg3);border-radius:20px;padding:4px 10px;font-size:10px;color:var(--txt3);border:0.5px solid var(--bdr2);transition:all 0.2s}
.cloud.on{border-color:var(--blu);color:#93c5fd;background:var(--blu2)}
.ldr-track{margin:0 16px 2px;height:4px;background:linear-gradient(to right,#3b82f6,#ef4444);border-radius:2px}
input.ldr-inp{display:block;width:calc(100% - 32px);margin:0 16px 14px;accent-color:var(--grn);cursor:pointer}
.ldr-focus{display:flex;align-items:center;gap:12px;background:var(--bg3);border-radius:12px;padding:13px;margin:0 16px 14px;border:0.5px solid var(--bdr2)}
.magnify{width:46px;height:46px;border-radius:50%;background:var(--bg4);border:1.5px solid var(--bdr2);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.magnify i{font-size:20px;color:var(--txt3)}
.focus-val{font-size:11px;color:var(--grn);font-weight:600;margin-bottom:3px}
.focus-txt{font-size:12px;color:var(--txt2);line-height:1.45;font-style:italic}
.ldr-cards{display:flex;gap:8px;margin:0 16px 14px}
.ldr-card{flex:1;background:var(--bg3);border-radius:10px;padding:10px;text-align:center;border:0.5px solid var(--bdr)}
.ldr-card-lbl{font-size:10px;margin-bottom:4px;font-weight:600}
.ldr-card-ex{font-size:11px;color:var(--txt2);line-height:1.4;font-style:italic}
.coach-box{background:var(--bg3);border-radius:14px;padding:14px;margin:0 16px 12px;border:0.5px solid var(--bdr2)}
.coach-row{display:flex;align-items:center;gap:10px;margin-bottom:11px}
.coach-av{width:38px;height:38px;border-radius:50%;background:var(--blu2);border:1.5px solid var(--blu);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.coach-av i{font-size:17px;color:var(--blu)}
.coach-nm{font-size:13px;font-weight:600;color:var(--txt)}
.coach-badge{display:inline-block;font-size:9px;background:var(--blu2);color:#93c5fd;border-radius:10px;padding:2px 8px;margin-top:2px;font-weight:500}
.sc-inv-pad{padding:0 16px}
.fb-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:20px;font-size:11px;font-weight:600;margin-bottom:9px}
.pill-grn{background:rgba(29,158,117,0.2);color:#5DCAA5}
.pill-amb{background:rgba(217,119,6,0.2);color:#fbbf24}
.fb-tip{font-size:12px;color:var(--txt3);font-style:italic;margin-bottom:14px;line-height:1.5}
.brug-opts{padding:0 16px}
.brug-opt{width:100%;text-align:left;background:var(--bg3);border:0.5px solid var(--bdr2);border-radius:11px;padding:12px 14px;color:var(--txt2);font-size:12px;cursor:pointer;margin-bottom:8px;line-height:1.45;font-family:var(--font);transition:border-color 0.15s,background 0.15s}
.brug-opt:hover{background:var(--bg4)}
.brug-opt.sel{border-color:var(--amb);background:var(--amb2);color:var(--txt)}
.brug-opt.ok{border-color:var(--grn);color:#5dcaa5;background:var(--grn4)}
.brug-opt.no{border-color:var(--red);color:#f87171;background:rgba(226,74,74,0.06)}
.wall-cards{display:flex;flex-direction:column;gap:9px;margin:12px 16px 16px}
.wall-card{background:var(--bg3);border-radius:12px;padding:13px 15px;border-left:3px solid var(--grn);border-top:0.5px solid var(--bdr2);border-right:0.5px solid var(--bdr2);border-bottom:0.5px solid var(--bdr2);animation:fadeUp 0.25s ease}
.wall-q{font-size:13px;color:var(--txt);line-height:1.55;margin-bottom:5px}
.wall-meta{font-size:10px;color:var(--txt3)}
.wall-likes{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:var(--txt3);margin-top:8px;cursor:pointer;border:none;background:none;font-family:var(--font);padding:0;transition:color 0.15s}
.wall-likes.liked{color:var(--grn)}
.wall-likes i{font-size:15px}
.profile-hero{text-align:center;padding:20px 16px 14px}
.av-big{width:76px;height:76px;border-radius:50%;background:var(--bg3);border:2px solid var(--grn);display:flex;align-items:center;justify-content:center;margin:0 auto 12px}
.prof-name{font-size:17px;font-weight:700;color:var(--txt)}
.prof-sub{font-size:11px;color:var(--txt3);margin-top:3px}
.badge-row{display:flex;gap:8px;justify-content:center;margin:12px 16px 16px;flex-wrap:wrap}
.badge-item{background:var(--bg3);border-radius:12px;padding:10px 14px;text-align:center;border:0.5px solid var(--bdr);min-width:80px;transition:border-color 0.3s,opacity 0.3s}
.badge-item.earned{border-color:var(--grn)}
.badge-ico{font-size:20px;color:var(--grn)}
.badge-lbl{font-size:10px;color:var(--txt3);margin-top:4px;font-weight:500}
.prog-bars{margin:0 16px 16px}
.prog-item{margin-bottom:14px}
.prog-lbl{display:flex;justify-content:space-between;font-size:11px;margin-bottom:5px}
.prog-lbl span:first-child{color:var(--txt2);font-weight:500}
.prog-lbl span:last-child{color:var(--grn);font-weight:600;font-family:var(--mono)}
.prog-track{height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.prog-fill{height:5px;background:var(--grn);border-radius:3px;transition:width 0.6s cubic-bezier(0.4,0,0.2,1)}
.total-pts-card{background:var(--bg3);border-radius:14px;padding:18px;text-align:center;border:0.5px solid var(--bdr2);margin:0 16px 16px}
.total-pts-n{font-size:36px;font-weight:700;color:var(--grn);font-family:var(--mono)}
.total-pts-l{font-size:11px;color:var(--txt3);margin-top:3px;font-weight:500}
.loader{text-align:center;padding:32px;color:var(--txt3);font-size:13px}
.spin{display:inline-block;width:18px;height:18px;border:2px solid var(--bg4);border-top-color:var(--grn);border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:-4px;margin-right:8px}
@keyframes spin{to{transform:rotate(360deg)}}
.sp8{height:8px}.sp16{height:16px}
.pad16{padding:0 16px}
@media(min-width:480px){
  body{background:#060b16;padding:20px 0;align-items:center;min-height:100vh}
  .phone-wrap{min-height:auto;border-radius:32px;border:1.5px solid var(--bdr2);overflow:hidden;max-height:820px}
  .phone-wrap::before{border-radius:32px}
  .screen{max-height:calc(820px - 130px)}
  .bottom-nav{border-radius:0 0 32px 32px;position:sticky;bottom:0;transform:none;left:auto}
}
</style>
</head>
